# =============================================================================
# CryptoEdy — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. This file IS committed (no real secrets here).
# =============================================================================

# Database
DATABASE_URL=                        # PostgreSQL connection string (Neon / Supabase / Railway)

# Payload CMS
PAYLOAD_SECRET=                      # Random 32-char string — signs Payload CMS sessions

# Authentication (NextAuth v5)
AUTH_SECRET=                         # Random 32-char string — signs NextAuth JWTs (run: npx auth secret)
NEXTAUTH_URL=http://localhost:3000   # Full app URL (update for staging/production)

# Payments — Coinbase Commerce
COINBASE_COMMERCE_API_KEY=           # From Coinbase Commerce dashboard
COINBASE_COMMERCE_WEBHOOK_SECRET=    # Webhook signing secret from Coinbase Commerce

# Market Data APIs
COINGECKO_API_KEY=                   # CoinGecko Pro API key (free tier = 50 req/min)
DEFILLAMA_BASE_URL=https://api.llama.fi  # Public API — no key required

# Email — Resend (https://resend.com)
RESEND_API_KEY=                      # From Resend dashboard — used for transactional emails
