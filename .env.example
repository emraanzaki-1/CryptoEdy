# =============================================================================
# CryptoEdy — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. This file IS committed (no real secrets here).
#
# Marked as [REQUIRED] — app throws on startup if missing.
# Marked as [RECOMMENDED] — has fallback but must be set in production.
# Marked as [OPTIONAL] — safe to omit; feature degrades gracefully.
# Marked as [PLANNED] — not yet wired up; add before enabling the feature.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=                        # [REQUIRED] PostgreSQL connection string (e.g. Neon / Supabase / Railway)
                                     # Format: postgresql://user:password@host:5432/dbname?sslmode=require


# -----------------------------------------------------------------------------
# Payload CMS
# -----------------------------------------------------------------------------
PAYLOAD_SECRET=                      # [REQUIRED] Random 32-char string — signs Payload CMS sessions
                                     # Generate: openssl rand -base64 32


# -----------------------------------------------------------------------------
# Authentication — NextAuth v5 (Auth.js)
# -----------------------------------------------------------------------------
AUTH_SECRET=                         # [REQUIRED] Random 32-char string — signs NextAuth JWTs
                                     # Generate: npx auth secret  OR  openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # [REQUIRED] Full public URL of the app (no trailing slash)
                                     # Production: https://cryptoedy.com


# -----------------------------------------------------------------------------
# App Secrets
# -----------------------------------------------------------------------------
REFERRAL_SECRET=                     # [RECOMMENDED] Random 32-char string — derives referral codes from email via HMAC
                                     # Generate: openssl rand -base64 32

REVALIDATION_SECRET=                 # [RECOMMENDED] Random 32-char string — protects /api/revalidate cache-bust endpoint
                                     # Generate: openssl rand -base64 32


# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# -----------------------------------------------------------------------------
RESEND_API_KEY=                      # [REQUIRED] From Resend dashboard — used for all transactional emails
                                     # In development the shared onboarding@resend.dev sender is used automatically
                                     # In production ensure your domain (cryptoedy.com) is verified in Resend


# -----------------------------------------------------------------------------
# Payments — Provider Abstraction
# -----------------------------------------------------------------------------
PAYMENT_PROVIDER=thirdweb             # [RECOMMENDED] Active payment provider ('thirdweb' | 'coinbase')
                                      # Controls which provider the checkout API uses
                                      # Webhook routes are provider-specific and work regardless of this setting

NEXT_PUBLIC_APP_URL=http://localhost:3000  # [REQUIRED] Public URL — used for checkout success/cancel redirects

# --- Thirdweb ---
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=      # [REQUIRED if thirdweb] Client ID from thirdweb.com/dashboard
THIRDWEB_SECRET_KEY=                 # [REQUIRED if thirdweb] Server-side secret key from thirdweb dashboard
THIRDWEB_WEBHOOK_SECRET=             # [REQUIRED if thirdweb] HMAC secret for webhook signature verification
THIRDWEB_RECIPIENT_ADDRESS=          # [REQUIRED if thirdweb] Wallet address that receives USDC/USDT payments

# --- Coinbase Commerce (future provider) ---
COINBASE_COMMERCE_API_KEY=           # [PLANNED] From Coinbase Commerce dashboard
COINBASE_COMMERCE_WEBHOOK_SECRET=    # [PLANNED] Webhook signing secret from Coinbase Commerce dashboard

# --- Subscription Cron ---
CRON_SECRET=                         # [REQUIRED] Bearer token for /api/cron/subscription-check
                                      # Generate: openssl rand -base64 32


# -----------------------------------------------------------------------------
# Market Data APIs  [PLANNED — wire up before enabling market features]
# -----------------------------------------------------------------------------
COINGECKO_API_KEY=                   # [PLANNED] CoinGecko Pro API key — free tier allows 50 req/min
DEFILLAMA_BASE_URL=https://api.llama.fi  # [PLANNED] DefiLlama base URL — public API, no key required
